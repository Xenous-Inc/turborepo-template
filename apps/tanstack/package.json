{
    "$schema": "https://schemastore.org/package.json",
    "name": "tanstack",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "git clean -xdf .cache .turbo .tanstack .output node_modules",
        "dev": "pnpm with-env vite dev --port=3002",
        "build": "pnpm with-env vite build",
        "start": "pnpm with-env vite preview",
        "check": "biome check .",
        "check:fix": "biome check . --write",
        "check:unsafe": "biome check . --write --unsafe",
        "ci": "biome ci",
        "typecheck": "tsc --noEmit",
        "ui-add": "pnpm shadcn add",
        "with-env": "dotenvx run -f .env.local -f ../../.env --"
    },
    "dependencies": {
        "@fontsource-variable/geist": "^5.2.8",
        "@fontsource-variable/geist-mono": "^5.2.7",
        "@orpc/client": "catalog:orpc",
        "@orpc/server": "catalog:orpc",
        "@orpc/tanstack-query": "catalog:orpc",
        "@t3-oss/env-core": "catalog:",
        "@tabler/icons-react": "^3.36.1",
        "@tanstack/react-form": "catalog:",
        "@tanstack/react-query": "catalog:",
        "@tanstack/react-router": "^1.155.0",
        "@tanstack/react-router-ssr-query": "^1.155.0",
        "@tanstack/react-start": "^1.155.0",
        "@xenous/logger": "workspace:*",
        "@xenous/ui": "workspace:*",
        "@xenous/validators": "workspace:*",
        "better-auth": "catalog:",
        "jiti": "catalog:",
        "nitro": "3.0.1-alpha.1",
        "react": "catalog:react19",
        "react-dom": "catalog:react19",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "@dotenvx/dotenvx": "catalog:",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-query-devtools": "catalog:",
        "@tanstack/react-router-devtools": "^1.155.0",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "catalog:node22",
        "@types/react": "catalog:react19",
        "@types/react-dom": "catalog:react19",
        "@vitejs/plugin-react": "^5.1.2",
        "@xenous/biome-config": "workspace:*",
        "@xenous/typescript": "workspace:*",
        "server": "workspace:*",
        "shadcn": "^3.7.0",
        "typescript": "catalog:",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^6.0.5"
    }
}
