{
    "$schema": "https://turborepo.org/schema.json",
    "extends": ["//"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".output/**", ".nitro/**"]
        },
        "dev": {
            "persistent": true
        },
        "auth:sync": {
            "cache": false,
            "persistent": true
        }
    }
}
