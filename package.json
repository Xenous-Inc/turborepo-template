{
    "$schema": "https://schemastore.org/package.json",
    "name": "xenous",
    "private": true,
    "engines": {
        "node": ">=24.11",
        "pnpm": "^10"
    },
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "scripts": {
        "prepare": "pnpm ruler:apply",
        "clean": "git clean -xdf node_modules",
        "clean:ws": "turbo clean",
        "dev": "turbo dev",
        "dev:server": "turbo -F server dev",
        "dev:tanstack": "turbo -F tanstack dev",
        "dev:web": "turbo -F web dev",
        "build": "turbo build",
        "check": "turbo run check --continue",
        "check:fix": "turbo run check:fix --continue",
        "check:unsafe": "turbo run check:unsafe --continue",
        "check:ws": "pnpx sherif@latest",
        "ci": "turbo run ci --continue",
        "typecheck": "turbo run typecheck --continue",
        "postinstall": "pnpm check:ws",
        "db:studio": "turbo -F @xenous/db db:studio",
        "db:push": "turbo -F @xenous/db db:push",
        "db:generate": "turbo -F @xenous/db db:generate",
        "db:migrate": "turbo -F @xenous/db db:migrate",
        "deps:check": "pnpx taze -r --maturity-period 7",
        "deps:update": "pnpx taze -r -w --maturity-period 7",
        "ruler:apply": "pnpx @intellectronica/ruler@latest apply --local-only",
        "rename": "bash ./rename.sh",
        "postrename": "pnpm check:ws -f && pnpm check:fix -- --linter-enabled false"
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@turbo/gen": "^2.8.20",
        "@xenous/biome-config": "workspace:*",
        "lefthook": "^2.1.4",
        "turbo": "^2.8.20",
        "typescript": "catalog:"
    }
}
